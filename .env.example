# ==============================================================================
# AI Copilot - Environment Configuration
# Copy this file to .env and configure the variables below.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. LLM Providers (Text Generation & Structured Extraction)
# ------------------------------------------------------------------------------
# Set your preferred provider. Options: groq, gemini, together, mistral, cohere, 
# huggingface, anthropic, openai, ollama (default: groq)
LLM_PROVIDER=groq

# API Keys for the respective providers you wish to use:
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# For local Ollama:
# OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------------------
# 2. Embeddings (Vector Search)
# ------------------------------------------------------------------------------
# Set the embedding provider. Options: local, gemini, ollama (default: local)
EMBEDDING_PROVIDER=local

# If using 'local', you can specify the sentence-transformer model:
# Options include: BAAI/bge-large-en-v1.5, BAAI/bge-small-en-v1.5, all-MiniLM-L6-v2
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ------------------------------------------------------------------------------
# 3. Database (Postgres / SQLite)
# ------------------------------------------------------------------------------
# The persistent database for Documents, Conversations, Messages, and Extractions.
# If unset, defaults to a local SQLite file (Backend/app.sqlite).
# For production, use Supabase Postgres:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ------------------------------------------------------------------------------
# 4. Storage (Object Storage)
# ------------------------------------------------------------------------------
# Where original uploaded files are stored.
# If unset, defaults to local filesystem (Backend/storage/).
# For production, use Supabase Storage:
# SUPABASE_URL=https://[PROJECT_REF].supabase.co
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# SUPABASE_STORAGE_BUCKET=documents

# ------------------------------------------------------------------------------
# 5. Authentication
# ------------------------------------------------------------------------------
# Enable Firebase Authentication middleware. Default: false
AUTH_ENABLED=false
# If true, the path to the Firebase Admin SDK service account JSON:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ------------------------------------------------------------------------------
# 6. OCR Configuration (Optional)
# ------------------------------------------------------------------------------
# Custom directory for OCR engine model weights (PaddleOCR, DocTR, TrOCR).
# Default: Backend/ocr_assets
# OCR_ASSETS_DIR=/path/to/your/ocr_assets
